{
  "name": "learnprint",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HYCU 학습 이력서 — 흩어진 학습 경험을 AI가 역량·증거 기반 이력서로 재구성 (2026 HYCU AI 학습법 공모전)",
  "scripts": {
    "dev": "vite",
    "serve": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "build": "tsc -b && tsc -p tsconfig.server.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
