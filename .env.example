# cliproxy(OpenAI 호환) LLM 백엔드 — 실제 키/주소는 .env 에만 두세요 (커밋 금지)
# .env 는 .gitignore 로 제외되며, 이 .env.example 만 저장소에 포함됩니다.

# OpenAI 호환 LLM 엔드포인트 base URL (예: cliproxy /v1)
LLM_BASE_URL=http://YOUR_CLIPROXY_HOST:8317/v1

# 서버 측에서만 사용하는 API 키 (브라우저로 절대 노출되지 않음)
LLM_API_KEY=replace-with-your-server-side-key

# 기본 모델 (한국어 학습 코칭 벤치마크 기준 권장값)
LLM_MODEL=gemini-3-flash

# BFF/정적 서버 포트
PORT=4173
